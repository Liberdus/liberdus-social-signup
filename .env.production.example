SIGNUP_HOST=127.0.0.1
SIGNUP_PORT=<production internal port>
SIGNUP_ALLOWED_ORIGINS=https://liberdus.com
SIGNUP_FRONTEND_RETURN_URL=https://liberdus.com/social/
SIGNUP_FRONTEND_RETURN_URLS=https://liberdus.com/social/
SIGNUP_COOKIE_SECURE=true
SIGNUP_DB_PATH=data/liberdus-social-signup.sqlite
SIGNUP_TRUST_PROXY=true

# In-memory backend throttles. Tune with any edge/proxy limits used in production.
SIGNUP_ADMIN_LOGIN_IP_LIMIT=20
SIGNUP_ADMIN_LOGIN_USERNAME_LIMIT=8
SIGNUP_ADMIN_LOGIN_WINDOW_SECONDS=900
SIGNUP_ADMIN_LOGIN_BLOCK_SECONDS=900
SIGNUP_WRITE_IP_LIMIT=30
SIGNUP_SIGNUP_RATE_WINDOW_SECONDS=600
SIGNUP_READ_IP_LIMIT=120
SIGNUP_READ_RATE_WINDOW_SECONDS=300
SIGNUP_SOCIAL_FLOW_IP_LIMIT=60
SIGNUP_SOCIAL_RATE_WINDOW_SECONDS=600

# X / Twitter OAuth 1.0a.
X_API_KEY=
X_API_SECRET=
X_OAUTH1_CALLBACK_URL=https://att.liberdus.com/social-signup/api/x/callback

# Admin login for /frontend/admin/. Store a strong secret in production.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Optional future verification config.
X_TARGET_ACCOUNT_IDS=

# Discord.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_OAUTH_CALLBACK_URL=https://att.liberdus.com/social-signup/api/discord/callback
DISCORD_GUILD_ID=
DISCORD_INVITE_URL=

# Telegram.
TELEGRAM_BOT_USERNAME=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_INVITE_URL=

# LinkedIn.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_OAUTH_CALLBACK_URL=https://att.liberdus.com/social-signup/api/linkedin/callback

# GitHub.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_CALLBACK_URL=https://att.liberdus.com/social-signup/api/github/callback
GITHUB_TARGET_REPO=Liberdus/web-client-v2
GITHUB_TARGET_ORG=Liberdus
GITHUB_OAUTH_SCOPES=read:user

# YouTube / Google.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_OAUTH_CALLBACK_URL=https://att.liberdus.com/social-signup/api/youtube/callback
YOUTUBE_TARGET_CHANNEL_HANDLE=Liberdus
YOUTUBE_TARGET_CHANNEL_ID=
YOUTUBE_TARGET_CHANNEL_URL=https://www.youtube.com/@Liberdus
YOUTUBE_OAUTH_SCOPES=openid profile https://www.googleapis.com/auth/youtube.readonly

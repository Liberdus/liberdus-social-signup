SIGNUP_HOST=127.0.0.1
SIGNUP_PORT=8788
SIGNUP_ALLOWED_ORIGINS=http://127.0.0.1:5503,http://localhost:5503
SIGNUP_FRONTEND_RETURN_URL=http://127.0.0.1:5503/frontend/
SIGNUP_FRONTEND_RETURN_URLS=http://127.0.0.1:5503/frontend/,http://localhost:5503/frontend/
SIGNUP_COOKIE_SECURE=auto
SIGNUP_DB_PATH=data/liberdus-social-signup.sqlite

# X / Twitter OAuth 1.0a. Configure callback URL in the X developer console.
X_API_KEY=
X_API_SECRET=
X_OAUTH1_CALLBACK_URL=http://127.0.0.1:8788/api/x/callback

# Admin login for /frontend/admin/. Store a strong secret in production.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Optional future verification config.
X_TARGET_ACCOUNT_IDS=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_OAUTH_CALLBACK_URL=http://127.0.0.1:8788/api/discord/callback
DISCORD_GUILD_ID=
DISCORD_INVITE_URL=
TELEGRAM_CHAT_ID=
